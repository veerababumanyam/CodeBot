# CodeBot Environment Configuration
# Copy this file to .env and fill in the values for local development.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# CODEBOT_DATABASE_URL=postgresql+asyncpg://codebot:codebot_dev@localhost:5432/codebot

# ── Redis ─────────────────────────────────────────────────────────────────────
# CODEBOT_REDIS_URL=redis://localhost:6379/0

# ── NATS ──────────────────────────────────────────────────────────────────────
# CODEBOT_NATS_URL=nats://localhost:4222

# ── Application ───────────────────────────────────────────────────────────────
# CODEBOT_DEBUG=true
# CODEBOT_LOG_LEVEL=INFO
